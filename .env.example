# Server
NODE_ENV=production
HOST=0.0.0.0
PORT=3000
BASE_URL=http://localhost:3000

# Security
JWT_SECRET=change-me-to-random-64-char-string
JWT_EXPIRES_IN=24h
# Token API (max 15 karakter total, gaya Fonnte)
API_KEY_PREFIX=
API_KEY_MAX_LENGTH=15
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# IP Whitelist (comma-separated, empty = disabled)
IP_WHITELIST=

# Database — sqlite (default) atau mysql (phpMyAdmin / Laragon)
DB_DRIVER=mysql
DATABASE_PATH=storage/database.sqlite

# MySQL (jika DB_DRIVER=mysql)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=whatsapp_service

# WhatsApp / Baileys
AUTH_STORAGE_PATH=storage/auth
MAX_SESSIONS=10
RECONNECT_INTERVAL_MS=5000
MAX_RECONNECT_ATTEMPTS=15

# Queue
QUEUE_DELAY_MIN_MS=3000
QUEUE_DELAY_MAX_MS=8000
QUEUE_COOLDOWN_MS=5000
QUEUE_MAX_RETRIES=3
QUEUE_CONCURRENCY=2

# Webhook
WEBHOOK_TIMEOUT_MS=10000
WEBHOOK_MAX_RETRIES=3

# Logging
LOG_LEVEL=info
LOG_DIR=logs
LOG_ROTATE_SIZE=10m
LOG_ROTATE_INTERVAL=1d
LOG_RETAIN_DAYS=14

# Dashboard
DASHBOARD_ENABLED=true

# Default admin (created on first boot if no users exist)
# Login dashboard & API: nomor WhatsApp (ADMIN_PHONE wajib)
# Ubah nilai di bawah lalu jalankan: npm run admin:reset
ADMIN_EMAIL=admin@localhost
ADMIN_PHONE=62881081871528
ADMIN_PASSWORD=changeme123
ADMIN_NAME=Super Admin

# Fonnte — alert WA saat reconnect gagal berulang (opsional)
# Token device dari dashboard Fonnte → menu Device → Token
FONNTE_TOKEN=
FONNTE_ENABLED=true
FONNTE_API_URL=https://api.fonnte.com/send
FONNTE_ALERT_COOLDOWN_MS=1800000
FONNTE_TIMEOUT_MS=10000

# CORS
CORS_ORIGIN=*
