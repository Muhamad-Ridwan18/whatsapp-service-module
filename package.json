{
  "name": "whatsapp-service-module",
  "version": "1.0.0",
  "description": "Lightweight WhatsApp engine microservice for Laravel and other backends",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && npm run build:css",
    "postinstall": "npm run build:css",
    "build:css": "tailwindcss -i ./src/views/styles/input.css -o ./public/css/app.css --minify",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "tsx src/services/database/migrate.ts",
    "admin:reset": "tsx src/scripts/reset-admin.ts",
    "admin:verify-login": "tsx src/scripts/verify-login.ts",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop whatsapp-service"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "whatsapp",
    "baileys",
    "microservice",
    "laravel"
  ],
  "license": "MIT",
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.2",
    "@fastify/formbody": "^8.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/jwt": "^9.0.4",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/static": "^8.1.0",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.1",
    "@fastify/view": "^10.0.2",
    "@fastify/websocket": "^11.0.2",
    "@whiskeysockets/baileys": "^6.7.16",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.8.1",
    "mysql2": "^3.12.0",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "fastify": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "pino-roll": "^2.0.0",
    "qrcode": "^1.5.4",
    "uuid": "^11.0.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/ejs": "^3.1.5",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.5",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
