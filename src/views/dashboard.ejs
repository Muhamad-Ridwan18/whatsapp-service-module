<!DOCTYPE html>
<html lang="id" class="dark">
<head>
  <%- include('partials/head', { title: 'Beranda' }) %>
</head>
<body
  class="bg-surface min-h-screen font-sans text-gray-200"
  data-scan-session="<%= scanSession || '' %>"
  data-active-tab="<%= activeTab || 'whatsapp' %>"
>
  <%- include('partials/nav', { currentUser, activePage: 'dashboard' }) %>

  <main class="max-w-5xl mx-auto px-4 py-6">
    <header class="mb-6">
      <h1 class="text-xl font-bold text-white">Halo, <%= currentUser.email.split('@')[0] %></h1>
      <p class="text-sm text-gray-500 mt-1">Kelola koneksi WhatsApp dan API untuk integrasi website Anda.</p>
    </header>

    <%- include('partials/alerts') %>

    <% if (newApiKey) { %>
      <div class="card mb-6 border-accent/30 bg-accent/5">
        <p class="section-title text-accent">API Key baru — simpan sekarang!</p>
        <p class="section-desc mb-4">Key hanya ditampilkan sekali. Masukkan ke file <code class="text-accent">.env</code> Laravel:</p>
        <code class="block text-xs text-gray-500 mb-2">WHATSAPP_API_KEY=...</code>
        <div class="flex flex-col sm:flex-row gap-2">
          <code id="newApiKeyValue" class="flex-1 bg-surface px-3 py-2.5 rounded-lg text-sm text-white font-mono break-all border border-surface-200"><%= newApiKey %></code>
          <button type="button" id="btnCopyKey" class="btn-primary shrink-0">Salin Key</button>
        </div>
      </div>
    <% } %>

    <!-- Ringkasan -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-6">
      <div class="stat-card">
        <span class="text-xs text-gray-500">Total Session</span>
        <span class="text-2xl font-bold text-white"><%= stats.totalSessions %></span>
      </div>
      <div class="stat-card">
        <span class="text-xs text-gray-500">Terhubung</span>
        <span class="text-2xl font-bold text-accent"><%= stats.connected %></span>
      </div>
      <div class="stat-card">
        <span class="text-xs text-gray-500">Pesan Hari Ini</span>
        <span class="text-2xl font-bold text-white"><%= stats.messagesToday %></span>
      </div>
      <div class="stat-card">
        <span class="text-xs text-gray-500">Antrian Kirim</span>
        <span class="text-2xl font-bold text-white"><%= stats.queue.pending %></span>
      </div>
    </div>

    <!-- Tabs -->
    <div class="flex gap-1 p-1 bg-surface-50 border border-surface-200 rounded-xl mb-6 w-fit" role="tablist">
      <button type="button" class="tab-btn tab-btn-active" data-tab="whatsapp" role="tab">WhatsApp</button>
      <button type="button" class="tab-btn" data-tab="apikeys" role="tab">API Key</button>
      <button type="button" class="tab-btn" data-tab="activity" role="tab">Aktivitas</button>
    </div>

    <!-- TAB: WhatsApp -->
    <div id="panel-whatsapp" class="tab-panel space-y-6">
      <div class="card">
        <div class="flex items-start gap-3 mb-5">
          <span class="step-num">1</span>
          <div>
            <h2 class="section-title">Hubungkan Nomor WhatsApp</h2>
            <p class="section-desc">Masukkan nomor yang akan dipakai, lalu scan QR dari aplikasi WhatsApp di HP.</p>
          </div>
        </div>
        <form method="POST" action="/dashboard/session/create" class="grid sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-medium text-gray-400 mb-1.5">Nomor WhatsApp</label>
            <input type="tel" id="phoneNumber" name="phoneNumber" placeholder="628123456789" value="<%= phoneHint || '' %>" class="input-field" required>
            <p class="text-[11px] text-gray-600 mt-1">Format: 62 + nomor tanpa 0 di depan</p>
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-400 mb-1.5">ID Session <span class="text-gray-600">(opsional)</span></label>
            <input type="text" id="sessionId" name="sessionId" placeholder="Otomatis: wa-628..." class="input-field">
          </div>
          <div class="sm:col-span-2">
            <button type="submit" class="btn-primary">Buat Session &amp; Tampilkan QR</button>
          </div>
        </form>
      </div>

      <div class="card" id="qrSection">
        <div class="flex items-start gap-3 mb-4">
          <span class="step-num">2</span>
          <div class="flex-1">
            <h2 class="section-title">Scan QR Code</h2>
            <p class="section-desc">Buka WhatsApp → Perangkat Tertaut → Tautkan perangkat</p>
          </div>
        </div>
        <div id="qrBox" class="flex items-center justify-center bg-surface rounded-xl min-h-[240px] border border-dashed border-surface-200">
          <div class="text-center px-6">
            <p class="text-gray-400 text-sm">Buat session di atas untuk menampilkan QR</p>
            <p class="text-gray-600 text-xs mt-1">atau klik "Tampilkan QR" pada session yang ada</p>
          </div>
        </div>
        <p id="qrStatus" class="text-xs text-gray-500 mt-3 text-center"></p>
      </div>

      <div class="card">
        <h2 class="section-title mb-1">Daftar Session</h2>
        <p class="section-desc mb-4">Semua nomor WhatsApp yang terdaftar di sistem.</p>
        <% if (sessions.length === 0) { %>
          <div class="empty-state">Belum ada session. Hubungkan nomor WhatsApp di atas.</div>
        <% } else { %>
          <div class="table-wrap">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Session</th>
                  <th>Status</th>
                  <th>Nomor</th>
                  <th>Aksi</th>
                </tr>
              </thead>
              <tbody>
                <% sessions.forEach(s => {
                  const st = sessionStatus[s.status] || { label: s.status, class: 'badge-muted' };
                %>
                  <tr>
                    <td class="font-mono text-xs text-gray-300"><%= s.session_id %></td>
                    <td><span class="<%= st.class %>"><%= st.label %></span></td>
                    <td class="text-gray-400"><%= s.phone_number || '—' %></td>
                    <td class="whitespace-nowrap">
                      <button type="button" class="btn-ghost text-accent btn-show-qr" data-session="<%= s.session_id %>">QR</button>
                      <form method="POST" action="/dashboard/session/<%= s.session_id %>/reconnect" class="inline">
                        <button type="submit" class="btn-ghost">Sambung ulang</button>
                      </form>
                      <form method="POST" action="/dashboard/session/<%= s.session_id %>/disconnect" class="inline">
                        <button type="submit" class="btn-ghost">Putuskan</button>
                      </form>
                      <form method="POST" action="/dashboard/session/<%= s.session_id %>/delete" class="inline" data-confirm="Hapus session <%= s.session_id %>? Data login ikut terhapus.">
                        <button type="submit" class="btn-danger">Hapus</button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>

      <% if (sessions.length > 0) { %>
      <div class="card">
        <h2 class="section-title mb-1">Kirim Pesan Uji</h2>
        <p class="section-desc mb-4">Coba kirim pesan untuk memastikan session berjalan normal.</p>
        <form method="POST" action="/dashboard/send-test" class="grid sm:grid-cols-2 gap-3">
          <div class="sm:col-span-2">
            <label class="block text-xs font-medium text-gray-400 mb-1.5">Dari session</label>
            <select name="sessionId" class="input-field">
              <% sessions.forEach(s => { %>
                <option value="<%= s.session_id %>"><%= s.session_id %> — <%= s.phone_number || 'belum terhubung' %></option>
              <% }) %>
            </select>
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-400 mb-1.5">Ke nomor</label>
            <input type="text" name="to" placeholder="628123456789" class="input-field" required>
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-400 mb-1.5">Pesan</label>
            <input type="text" name="message" placeholder="Halo, ini pesan uji" class="input-field" required>
          </div>
          <div class="sm:col-span-2">
            <button type="submit" class="btn-primary">Kirim Pesan</button>
          </div>
        </form>
      </div>
      <% } %>
    </div>

    <!-- TAB: API Keys -->
    <div id="panel-apikeys" class="tab-panel hidden space-y-6">
      <div class="card">
        <h2 class="section-title mb-1">Buat API Key</h2>
        <p class="section-desc mb-4">Key ini dipakai website Laravel untuk kirim pesan lewat API. Header: <code class="text-gray-400">Authorization: Bearer KEY</code></p>
        <form method="POST" action="/dashboard/api-keys/create" class="space-y-3 max-w-lg">
          <div>
            <label class="block text-xs font-medium text-gray-400 mb-1.5">Nama / label</label>
            <input type="text" name="name" placeholder="Contoh: Website Toko Utama" class="input-field" required>
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-400 mb-1.5">Webhook URL <span class="text-gray-600">(opsional)</span></label>
            <input type="url" name="webhook_url" placeholder="https://website.com/webhook/whatsapp" class="input-field">
            <p class="text-[11px] text-gray-600 mt-1">Notifikasi otomatis saat ada pesan masuk/keluar</p>
          </div>
          <button type="submit" class="btn-primary">Buat API Key</button>
        </form>
      </div>

      <div class="card">
        <h2 class="section-title mb-4">API Key Aktif</h2>
        <% if (!apiKeys || apiKeys.length === 0) { %>
          <div class="empty-state">Belum ada API key. Buat key untuk integrasi Laravel.</div>
        <% } else { %>
          <div class="table-wrap">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Nama</th>
                  <th>Key</th>
                  <th>Status</th>
                  <th>Terakhir dipakai</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% apiKeys.forEach(k => { %>
                  <tr>
                    <td class="text-gray-200"><%= k.name %></td>
                    <td class="font-mono text-xs text-gray-500"><%= k.prefix %>••••</td>
                    <td>
                      <% if (k.is_active) { %><span class="badge-success">Aktif</span>
                      <% } else { %><span class="badge-error">Nonaktif</span><% } %>
                    </td>
                    <td class="text-xs text-gray-500"><%= k.last_used_at || 'Belum pernah' %></td>
                    <td>
                      <% if (k.is_active) { %>
                        <form method="POST" action="/dashboard/api-keys/<%= k.id %>/revoke" data-confirm="Nonaktifkan API key ini? Website tidak bisa kirim pesan lagi.">
                          <button type="submit" class="btn-danger">Nonaktifkan</button>
                        </form>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>

    <!-- TAB: Aktivitas -->
    <div id="panel-activity" class="tab-panel hidden space-y-6">
      <div class="card">
        <h2 class="section-title mb-1">Pesan Terbaru</h2>
        <p class="section-desc mb-4">Riwayat pesan masuk dan keluar.</p>
        <% if (recentMessages.length === 0) { %>
          <div class="empty-state">Belum ada pesan tercatat.</div>
        <% } else { %>
          <div class="space-y-2">
            <% recentMessages.forEach(m => { %>
              <div class="flex items-center justify-between py-2 border-b border-surface-200/40 text-sm">
                <div>
                  <span class="text-gray-300"><%= m.session_id %></span>
                  <span class="text-gray-600 mx-1">→</span>
                  <span class="text-gray-400"><%= m.to_number %></span>
                </div>
                <span class="<%= m.direction === 'outbound' ? 'badge-success' : 'badge-muted' %>">
                  <%= m.direction === 'outbound' ? 'Keluar' : 'Masuk' %> · <%= m.status %>
                </span>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>

      <div class="card">
        <h2 class="section-title mb-1">Log Sistem</h2>
        <p class="section-desc mb-4">Aktivitas API dan kejadian penting.</p>
        <% if (!auditLogs || auditLogs.length === 0) { %>
          <div class="empty-state">Belum ada log aktivitas.</div>
        <% } else { %>
          <div class="table-wrap">
            <table class="data-table text-xs">
              <thead>
                <tr>
                  <th>Waktu</th>
                  <th>Kejadian</th>
                  <th>Detail</th>
                </tr>
              </thead>
              <tbody>
                <% auditLogs.forEach(log => { %>
                  <tr>
                    <td class="text-gray-500 whitespace-nowrap"><%= log.created_at %></td>
                    <td class="text-gray-300"><%= auditLabels[log.action] || log.action %></td>
                    <td class="text-gray-500 truncate max-w-[200px]"><%= log.resource || log.ip_address || '—' %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </main>

  <script src="/public/js/dashboard.js" defer></script>
</body>
</html>
