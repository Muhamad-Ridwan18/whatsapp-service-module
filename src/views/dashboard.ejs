<!DOCTYPE html>
<html lang="id" class="dark">
<head>
  <%- include('partials/head', { title: 'Beranda' }) %>
</head>
<body data-scan-session="<%= scanSession || '' %>" data-active-tab="<%= activeTab || 'whatsapp' %>">
  <%- include('partials/sidebar', { currentUser, activePage: 'dashboard', pageTitle: 'Beranda' }) %>

  <div class="page-inner">
    <header class="page-header">
      <p class="page-eyebrow">Panel Admin</p>
      <h1 class="page-title">Kelola WhatsApp &amp; API</h1>
      <p class="page-subtitle">Hubungkan nomor, kelola session, dan integrasikan ke website Laravel Anda.</p>
    </header>

    <%- include('partials/alerts') %>

    <% if (newApiKey) { %>
    <div class="card-highlight">
      <div class="card-header">
        <p class="card-title text-brand-light">API Key berhasil dibuat</p>
        <p class="card-desc">Simpan key ini sekarang — tidak akan ditampilkan lagi.</p>
      </div>
      <div class="card-body space-y-3">
        <p class="hint font-mono">WHATSAPP_API_KEY=</p>
        <code id="newApiKeyValue" class="block w-full bg-bg border border-border rounded-lg px-4 py-3 text-sm font-mono text-brand-light break-all"><%= newApiKey %></code>
        <button type="button" id="btnCopyKey" class="btn-brand">Salin Key</button>
      </div>
    </div>
    <% } %>

    <!-- Stats -->
    <div class="stats-strip">
      <div class="stat-item">
        <p class="stat-item-label">Total session</p>
        <p class="stat-item-value"><%= stats.totalSessions %></p>
      </div>
      <div class="stat-item">
        <p class="stat-item-label">Terhubung</p>
        <p class="stat-item-value stat-item-value--accent"><%= stats.connected %></p>
      </div>
      <div class="stat-item">
        <p class="stat-item-label">Pesan hari ini</p>
        <p class="stat-item-value"><%= stats.messagesToday %></p>
      </div>
      <div class="stat-item">
        <p class="stat-item-label">Antrian</p>
        <p class="stat-item-value"><%= stats.queue.pending %></p>
      </div>
    </div>

    <!-- Desktop tabs -->
    <div class="tabs-desktop" role="tablist" aria-label="Bagian dashboard">
      <button type="button" class="tab-active" data-tab="whatsapp" role="tab">WhatsApp</button>
      <button type="button" class="tab" data-tab="apikeys" role="tab">API Key</button>
      <button type="button" class="tab" data-tab="activity" role="tab">Aktivitas</button>
    </div>

    <!-- WhatsApp -->
    <div id="panel-whatsapp" class="tab-panel space-y-4 sm:space-y-6">
      <div class="flow-grid">
        <div class="card">
          <div class="card-header">
            <div class="flex items-start gap-3">
              <span class="step-badge">1</span>
              <div>
                <h2 class="card-title">Hubungkan nomor</h2>
                <p class="card-desc">Masukkan nomor WhatsApp bisnis Anda.</p>
              </div>
            </div>
          </div>
          <div class="card-body">
            <form method="POST" action="/dashboard/session/create" class="space-y-4">
              <div>
                <label class="label" for="phoneNumber">Nomor WhatsApp</label>
                <input type="tel" id="phoneNumber" name="phoneNumber" placeholder="628123456789" value="<%= phoneHint || '' %>" class="input" required>
                <p class="hint">Format: 628123456789 (tanpa + dan tanpa 0 di depan)</p>
              </div>
              <div>
                <label class="label" for="sessionId">ID session <span class="text-txt-muted font-normal">(opsional)</span></label>
                <input type="text" id="sessionId" name="sessionId" placeholder="Otomatis dari nomor" class="input font-mono text-xs">
              </div>
              <button type="submit" class="btn-brand">Buat session &amp; tampilkan QR</button>
            </form>
          </div>
        </div>

        <div class="card" id="qrSection">
          <div class="card-header">
            <div class="flex items-start gap-3">
              <span class="step-badge">2</span>
              <div>
                <h2 class="card-title">Scan QR code</h2>
                <p class="card-desc">WhatsApp → Perangkat tertaut → Tautkan perangkat</p>
              </div>
            </div>
          </div>
          <div class="card-body">
            <div id="qrBox" class="qr-frame">
              <div class="text-center px-4">
                <p class="text-sm text-txt-muted">QR akan muncul setelah session dibuat</p>
              </div>
            </div>
            <p id="qrStatus" class="hint text-center mt-3"></p>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <h2 class="card-title">Daftar session</h2>
          <p class="card-desc">Nomor WhatsApp yang terhubung ke sistem.</p>
        </div>
        <div class="card-body">
          <% if (sessions.length === 0) { %>
            <div class="empty">
              <p class="empty-text">Belum ada session. Hubungkan nomor di atas.</p>
            </div>
          <% } else { %>
            <div class="session-cards">
              <%- include('partials/session-list', { sessions, sessionStatus }) %>
            </div>
            <div class="table-desktop">
              <table class="table">
                <thead>
                  <tr><th>Session</th><th>Status</th><th>Nomor</th><th>Aksi</th></tr>
                </thead>
                <tbody>
                  <% sessions.forEach(s => {
                    const st = sessionStatus[s.status] || { label: s.status, class: 'badge-muted' };
                  %>
                  <tr>
                    <td class="font-mono text-xs text-txt-primary"><%= s.session_id %></td>
                    <td><span class="<%= st.class %>"><%= st.label %></span></td>
                    <td><%= s.phone_number || '—' %></td>
                    <td>
                      <div class="flex flex-wrap gap-1">
                        <button type="button" class="btn-ghost text-brand btn-show-qr" data-session="<%= s.session_id %>">QR</button>
                        <form method="POST" action="/dashboard/session/<%= s.session_id %>/reconnect" class="inline"><button type="submit" class="btn-ghost">Ulang</button></form>
                        <form method="POST" action="/dashboard/session/<%= s.session_id %>/disconnect" class="inline"><button type="submit" class="btn-ghost">Putus</button></form>
                        <form method="POST" action="/dashboard/session/<%= s.session_id %>/delete" class="inline" data-confirm="Hapus session ini?">
                          <button type="submit" class="btn-danger">Hapus</button>
                        </form>
                      </div>
                    </td>
                  </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      </div>

      <% if (sessions.length > 0) { %>
      <div class="card">
        <div class="card-header">
          <h2 class="card-title">Kirim pesan uji</h2>
          <p class="card-desc">Pastikan session sudah terhubung sebelum mengirim.</p>
        </div>
        <div class="card-body">
          <form method="POST" action="/dashboard/send-test" class="space-y-4">
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
              <div>
                <label class="label">Session</label>
                <select name="sessionId" class="select">
                  <% sessions.forEach(s => { %>
                    <option value="<%= s.session_id %>"><%= s.session_id %></option>
                  <% }) %>
                </select>
              </div>
              <div>
                <label class="label">Ke nomor</label>
                <input type="text" name="to" placeholder="628123456789" class="input" required>
              </div>
              <div class="sm:col-span-2 lg:col-span-1">
                <label class="label">Pesan</label>
                <input type="text" name="message" placeholder="Halo, pesan uji" class="input" required>
              </div>
            </div>
            <button type="submit" class="btn-brand">Kirim pesan</button>
          </form>
        </div>
      </div>
      <% } %>
    </div>

    <!-- API Keys -->
    <div id="panel-apikeys" class="tab-panel hidden space-y-4 sm:space-y-6">
      <div class="card">
        <div class="card-header">
          <h2 class="card-title">Buat API key</h2>
          <p class="card-desc">Untuk integrasi Laravel. Header: <code class="text-brand font-mono text-xs">Authorization: Bearer KEY</code></p>
        </div>
        <div class="card-body">
          <form method="POST" action="/dashboard/api-keys/create" class="space-y-4 max-w-lg">
            <div>
              <label class="label">Nama</label>
              <input type="text" name="name" placeholder="Website Toko Utama" class="input" required>
            </div>
            <div>
              <label class="label">Webhook URL <span class="text-txt-muted font-normal">(opsional)</span></label>
              <input type="url" name="webhook_url" placeholder="https://website.com/webhook/wa" class="input">
            </div>
            <button type="submit" class="btn-brand">Generate API key</button>
          </form>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <h2 class="card-title">Key terdaftar</h2>
          <p class="card-desc"><%= apiKeys ? apiKeys.length : 0 %> key di sistem</p>
        </div>
        <div class="card-body">
          <% if (!apiKeys || apiKeys.length === 0) { %>
            <div class="empty"><p class="empty-text">Belum ada API key.</p></div>
          <% } else { %>
            <div class="md:hidden space-y-3">
              <% apiKeys.forEach(k => { %>
              <div class="session-card">
                <div class="session-card-top">
                  <div>
                    <p class="text-sm font-medium text-txt-primary"><%= k.name %></p>
                    <p class="font-mono text-xs text-txt-muted mt-1"><%= k.prefix %>••••••</p>
                  </div>
                  <% if (k.is_active) { %><span class="badge-success">Aktif</span><% } else { %><span class="badge-error">Nonaktif</span><% } %>
                </div>
                <p class="text-xs text-txt-muted">Terakhir dipakai: <%= k.last_used_at || 'Belum' %></p>
                <% if (k.is_active) { %>
                <form method="POST" action="/dashboard/api-keys/<%= k.id %>/revoke" data-confirm="Nonaktifkan key ini?">
                  <button type="submit" class="btn-danger">Nonaktifkan</button>
                </form>
                <% } %>
              </div>
              <% }) %>
            </div>
            <div class="table-desktop">
              <table class="table">
                <thead><tr><th>Nama</th><th>Key</th><th>Status</th><th>Dipakai</th><th></th></tr></thead>
                <tbody>
                  <% apiKeys.forEach(k => { %>
                  <tr>
                    <td class="text-txt-primary font-medium"><%= k.name %></td>
                    <td class="font-mono text-xs"><%= k.prefix %>••••••</td>
                    <td><% if (k.is_active) { %><span class="badge-success">Aktif</span><% } else { %><span class="badge-error">Nonaktif</span><% } %></td>
                    <td class="text-xs"><%= k.last_used_at || 'Belum' %></td>
                    <td>
                      <% if (k.is_active) { %>
                      <form method="POST" action="/dashboard/api-keys/<%= k.id %>/revoke" data-confirm="Nonaktifkan key ini?">
                        <button type="submit" class="btn-danger">Nonaktifkan</button>
                      </form>
                      <% } %>
                    </td>
                  </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Activity -->
    <div id="panel-activity" class="tab-panel hidden space-y-4 sm:space-y-6">
      <div class="card">
        <div class="card-header">
          <h2 class="card-title">Pesan terbaru</h2>
        </div>
        <div class="card-body p-0 sm:p-0">
          <% if (recentMessages.length === 0) { %>
            <div class="empty"><p class="empty-text">Belum ada pesan.</p></div>
          <% } else { %>
            <div>
              <% recentMessages.forEach(m => { %>
              <div class="list-item">
                <div class="min-w-0 text-sm">
                  <p class="text-txt-primary font-medium truncate"><%= m.session_id %></p>
                  <p class="text-xs text-txt-muted truncate">→ <%= m.to_number %></p>
                </div>
                <span class="<%= m.direction === 'outbound' ? 'badge-success' : 'badge-muted' %> shrink-0">
                  <%= m.direction === 'outbound' ? 'Keluar' : 'Masuk' %>
                </span>
              </div>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <h2 class="card-title">Log sistem</h2>
        </div>
        <div class="card-body">
          <% if (!auditLogs || auditLogs.length === 0) { %>
            <div class="empty"><p class="empty-text">Belum ada aktivitas.</p></div>
          <% } else { %>
            <div class="md:hidden space-y-2">
              <% auditLogs.forEach(log => { %>
              <div class="session-card">
                <p class="text-xs text-txt-muted"><%= log.created_at %></p>
                <p class="text-sm font-medium text-txt-primary mt-1"><%= auditLabels[log.action] || log.action %></p>
                <p class="text-xs text-txt-muted mt-1 truncate"><%= log.resource || log.ip_address || '—' %></p>
              </div>
              <% }) %>
            </div>
            <div class="table-desktop">
              <table class="table text-xs">
                <thead><tr><th>Waktu</th><th>Kejadian</th><th>Detail</th></tr></thead>
                <tbody>
                  <% auditLogs.forEach(log => { %>
                  <tr>
                    <td class="whitespace-nowrap text-txt-muted"><%= log.created_at %></td>
                    <td class="text-txt-primary"><%= auditLabels[log.action] || log.action %></td>
                    <td class="truncate max-w-[200px]"><%= log.resource || log.ip_address || '—' %></td>
                  </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile bottom nav -->
  <nav class="mobile-bottom-nav" role="tablist" aria-label="Navigasi dashboard">
    <button type="button" class="mobile-nav-item active" data-tab="whatsapp" role="tab">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
      WhatsApp
    </button>
    <button type="button" class="mobile-nav-item" data-tab="apikeys" role="tab">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/></svg>
      API Key
    </button>
    <button type="button" class="mobile-nav-item" data-tab="activity" role="tab">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
      Aktivitas
    </button>
    <a href="/dashboard/settings" class="mobile-nav-item">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
      Profil
    </a>
  </nav>

  <%- include('partials/layout-end') %>
  <script src="/public/js/dashboard.js" defer></script>
</body>
</html>
