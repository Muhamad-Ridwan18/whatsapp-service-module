<!DOCTYPE html>
<html lang="id" class="dark">
<head>
  <%- include('partials/head', { title: 'Beranda' }) %>
</head>
<body data-scan-session="<%= scanSession || '' %>" data-active-tab="<%= activeTab || 'whatsapp' %>">
  <%- include('partials/sidebar', { currentUser, activePage: 'dashboard', pageTitle: 'Beranda' }) %>

  <div class="page-inner">
    <header class="page-header">
      <p class="page-eyebrow">Panel Klien</p>
      <h1 class="page-title">WhatsApp &amp; API</h1>
      <p class="page-subtitle">Satu nomor WhatsApp = satu session = satu API key. Semua terikat otomatis saat daftar.</p>
    </header>

    <%- include('partials/alerts') %>

    <% if (newApiKey) { %>
    <div class="card-highlight">
      <div class="card-header">
        <p class="card-title text-brand-light">API Key baru</p>
        <p class="card-desc">Simpan sekarang — tidak ditampilkan lagi. Key lama otomatis dinonaktifkan.</p>
      </div>
      <div class="card-body space-y-3">
        <p class="hint font-mono">WHATSAPP_API_KEY=</p>
        <code id="newApiKeyValue" class="block w-full bg-bg border border-border rounded-lg px-4 py-3 text-sm font-mono text-brand-light break-all"><%= newApiKey %></code>
        <button type="button" id="btnCopyKey" class="btn-brand">Salin Key</button>
      </div>
    </div>
    <% } %>

    <!-- Flow progress -->
    <div class="flow-progress">
      <div class="flow-step <%= account.phone ? 'flow-step--done' : '' %>">
        <span class="flow-step-num">1</span>
        <span class="flow-step-label">Daftar</span>
      </div>
      <div class="flow-step-line <%= account.sessionStatus === 'connected' ? 'flow-step-line--done' : '' %>"></div>
      <div class="flow-step <%= account.sessionStatus === 'connected' ? 'flow-step--done' : (account.sessionId ? 'flow-step--active' : '') %>">
        <span class="flow-step-num">2</span>
        <span class="flow-step-label">Scan QR</span>
      </div>
      <div class="flow-step-line <%= account.apiKeyActive ? 'flow-step-line--done' : '' %>"></div>
      <div class="flow-step <%= account.apiKeyActive ? 'flow-step--done' : (account.sessionStatus === 'connected' ? 'flow-step--active' : '') %>">
        <span class="flow-step-num">3</span>
        <span class="flow-step-label">API Key</span>
      </div>
      <div class="flow-step-line"></div>
      <div class="flow-step <%= account.sessionStatus === 'connected' && account.apiKeyActive ? 'flow-step--active' : '' %>">
        <span class="flow-step-num">4</span>
        <span class="flow-step-label">Integrasi</span>
      </div>
    </div>

    <!-- Account bundle -->
    <div class="account-bundle">
      <div class="account-bundle-item">
        <p class="account-bundle-label">Nomor WhatsApp</p>
        <p class="account-bundle-value"><%= account.phone || '—' %></p>
      </div>
      <div class="account-bundle-item">
        <p class="account-bundle-label">Session ID</p>
        <p class="account-bundle-value font-mono text-xs"><%= account.sessionId || '—' %></p>
      </div>
      <div class="account-bundle-item">
        <p class="account-bundle-label">Status koneksi</p>
        <p class="account-bundle-value">
          <% const stClass = sessionStatus[account.sessionStatus]?.class || 'badge-muted'; %>
          <span class="<%= stClass %>"><%= account.sessionStatusLabel %></span>
        </p>
      </div>
      <div class="account-bundle-item">
        <p class="account-bundle-label">API Key</p>
        <p class="account-bundle-value font-mono text-xs">
          <% if (account.apiKeyPrefix) { %>
            <%= account.apiKeyPrefix %>••••••
            <% if (account.apiKeyActive) { %><span class="badge-success ml-2">Aktif</span><% } %>
          <% } else { %>
            <span class="text-txt-muted">Belum ada</span>
          <% } %>
        </p>
      </div>
    </div>

    <!-- Stats -->
    <div class="stats-strip">
      <div class="stat-item">
        <p class="stat-item-label">Koneksi</p>
        <p class="stat-item-value stat-item-value--accent"><%= stats.connected %></p>
      </div>
      <div class="stat-item">
        <p class="stat-item-label">Pesan hari ini</p>
        <p class="stat-item-value"><%= stats.messagesToday %></p>
      </div>
      <div class="stat-item">
        <p class="stat-item-label">Antrian</p>
        <p class="stat-item-value"><%= stats.queue.pending %></p>
      </div>
      <div class="stat-item">
        <p class="stat-item-label">Gagal</p>
        <p class="stat-item-value"><%= stats.queue.failed || 0 %></p>
      </div>
    </div>

    <!-- Desktop tabs -->
    <div class="tabs-desktop" role="tablist" aria-label="Bagian dashboard">
      <button type="button" class="tab-active" data-tab="whatsapp" role="tab">WhatsApp</button>
      <button type="button" class="tab" data-tab="apikeys" role="tab">API Key</button>
      <button type="button" class="tab" data-tab="integrate" role="tab">Integrasi</button>
      <button type="button" class="tab" data-tab="activity" role="tab">Aktivitas</button>
    </div>

    <!-- WhatsApp panel -->
    <div id="panel-whatsapp" class="tab-panel space-y-4 sm:space-y-6">
      <% if (!account.sessionId) { %>
      <div class="card">
        <div class="card-body">
          <div class="empty">
            <p class="empty-text">Belum ada session. <a href="/register" class="text-brand">Daftar akun</a> dengan nomor WhatsApp Anda.</p>
          </div>
        </div>
      </div>
      <% } else { %>
      <div class="flow-grid">
        <div class="card" id="qrSection">
          <div class="card-header">
            <div class="flex items-start gap-3">
              <span class="step-badge">2</span>
              <div>
                <h2 class="card-title">Scan QR code</h2>
                <p class="card-desc">WhatsApp di HP → Perangkat tertaut → Tautkan perangkat. Scan dengan nomor <strong class="text-txt-primary"><%= account.phone %></strong>.</p>
              </div>
            </div>
          </div>
          <div class="card-body">
            <div id="qrBox" class="qr-frame">
              <div class="text-center px-4">
                <% if (account.sessionStatus === 'connected') { %>
                  <p class="text-3xl text-brand mb-2">✓</p>
                  <p class="text-brand font-semibold">Terhubung</p>
                  <p class="hint mt-1">Siap kirim pesan via API</p>
                <% } else { %>
                  <p class="text-sm text-txt-muted">Klik "Tampilkan QR" untuk memulai</p>
                <% } %>
              </div>
            </div>
            <p id="qrStatus" class="hint text-center mt-3"><%= account.sessionStatusLabel %></p>
            <div class="flex flex-wrap gap-2 mt-4 justify-center">
              <% if (account.sessionStatus !== 'connected') { %>
              <button type="button" id="btnShowQr" class="btn-brand" data-session="<%= account.sessionId %>">Tampilkan QR</button>
              <% } %>
              <form method="POST" action="/dashboard/session/reconnect" class="inline">
                <button type="submit" class="btn-outline">Sambung ulang</button>
              </form>
              <form method="POST" action="/dashboard/session/disconnect" class="inline" data-confirm="Putuskan koneksi WhatsApp?">
                <button type="submit" class="btn-ghost">Putuskan</button>
              </form>
            </div>
          </div>
        </div>

        <div class="card">
          <div class="card-header">
            <h2 class="card-title">Info session</h2>
            <p class="card-desc">Session otomatis dibuat saat pendaftaran — tidak perlu input manual.</p>
          </div>
          <div class="card-body space-y-0">
            <div class="info-row">
              <span class="info-row-label">Nomor terdaftar</span>
              <span class="info-row-value"><%= account.phone %></span>
            </div>
            <div class="info-row">
              <span class="info-row-label">Session ID</span>
              <span class="info-row-value font-mono text-xs"><%= account.sessionId %></span>
            </div>
            <div class="info-row">
              <span class="info-row-label">Format</span>
              <span class="info-row-value font-mono text-xs text-txt-muted">wa-&lt;nomor&gt;</span>
            </div>
            <div class="info-row border-0">
              <span class="info-row-label">Status</span>
              <span class="<%= stClass %>"><%= account.sessionStatusLabel %></span>
            </div>
          </div>
        </div>
      </div>

      <% if (account.sessionStatus === 'connected') { %>
      <div class="card">
        <div class="card-header">
          <h2 class="card-title">Kirim pesan uji</h2>
          <p class="card-desc">Menggunakan session <code class="text-brand font-mono text-xs"><%= account.sessionId %></code> secara otomatis.</p>
        </div>
        <div class="card-body">
          <form method="POST" action="/dashboard/send-test" class="space-y-4">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="label">Ke nomor</label>
                <input type="text" name="to" placeholder="628123456789" class="input" required>
              </div>
              <div>
                <label class="label">Pesan</label>
                <input type="text" name="message" placeholder="Halo, pesan uji" class="input" required>
              </div>
            </div>
            <button type="submit" class="btn-brand">Kirim pesan</button>
          </form>
        </div>
      </div>
      <% } %>
      <% } %>
    </div>

    <!-- API Key panel -->
    <div id="panel-apikeys" class="tab-panel hidden space-y-4 sm:space-y-6">
      <div class="card">
        <div class="card-header">
          <div class="flex items-start gap-3">
            <span class="step-badge">3</span>
            <div>
              <h2 class="card-title">API Key</h2>
              <p class="card-desc">Satu akun hanya punya <strong class="text-txt-primary">satu key aktif</strong>. Key terikat ke session <code class="text-brand font-mono text-xs"><%= account.sessionId || '—' %></code>.</p>
            </div>
          </div>
        </div>
        <div class="card-body space-y-4">
          <% if (account.apiKeyPrefix) { %>
          <div class="info-row border-0">
            <span class="info-row-label">Key aktif</span>
            <span class="info-row-value font-mono text-xs"><%= account.apiKeyPrefix %>••••••</span>
          </div>
          <% } else { %>
          <p class="text-sm text-txt-muted">API key dibuat otomatis saat daftar. Jika hilang, generate ulang di bawah.</p>
          <% } %>

          <form method="POST" action="/dashboard/api-key/rotate" class="space-y-4 max-w-lg" data-confirm="Generate key baru? Key lama akan dinonaktifkan.">
            <div>
              <label class="label">Webhook URL <span class="text-txt-muted font-normal">(opsional)</span></label>
              <input type="url" name="webhook_url" value="<%= account.webhookUrl || '' %>" placeholder="https://website.com/webhook/wa" class="input">
            </div>
            <button type="submit" class="btn-brand"><%= account.apiKeyPrefix ? 'Regenerasi API key' : 'Generate API key' %></button>
          </form>
        </div>
      </div>

      <% if (account.webhookUrl !== null && account.apiKeyPrefix) { %>
      <div class="card">
        <div class="card-header">
          <h2 class="card-title">Webhook</h2>
          <p class="card-desc">Update URL webhook tanpa mengganti API key.</p>
        </div>
        <div class="card-body">
          <form method="POST" action="/dashboard/webhook" class="flex flex-col sm:flex-row gap-3">
            <input type="url" name="webhook_url" value="<%= account.webhookUrl || '' %>" placeholder="https://website.com/webhook/wa" class="input flex-1">
            <button type="submit" class="btn-outline shrink-0">Simpan webhook</button>
          </form>
        </div>
      </div>
      <% } %>
    </div>

    <!-- Integrasi panel -->
    <div id="panel-integrate" class="tab-panel hidden space-y-4 sm:space-y-6">
      <div class="card">
        <div class="card-header">
          <div class="flex items-start gap-3">
            <span class="step-badge">4</span>
            <div>
              <h2 class="card-title">Integrasi Laravel</h2>
              <p class="card-desc">Tambahkan ke file <code class="text-brand font-mono text-xs">.env</code> website Anda. Tidak perlu kirim <code class="text-brand font-mono text-xs">sessionId</code> — otomatis dari API key.</p>
            </div>
          </div>
        </div>
        <div class="card-body space-y-4">
          <pre class="code-block" id="envSnippet">WHATSAPP_SERVICE_URL=<%= typeof baseUrl !== 'undefined' ? baseUrl : 'http://localhost:3000' %>
WHATSAPP_API_KEY=<span class="text-brand"><%= newApiKey || (account.apiKeyPrefix ? account.apiKeyPrefix + '••••••' : 'YOUR_API_KEY') %></span></pre>
          <button type="button" id="btnCopyEnv" class="btn-outline">Salin konfigurasi</button>

          <div class="mt-6 pt-6 border-t border-border">
            <p class="text-sm font-medium text-txt-primary mb-2">Contoh kirim pesan</p>
            <pre class="code-block text-xs">POST /api/message/send
Authorization: Bearer YOUR_API_KEY
Content-Type: application/json

{
  "to": "628123456789",
  "message": "Halo dari Laravel!"
}</pre>
            <p class="hint mt-2">Session <code class="font-mono"><%= account.sessionId || 'wa-628xxx' %></code> dipilih otomatis dari API key Anda.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Activity panel -->
    <div id="panel-activity" class="tab-panel hidden space-y-4 sm:space-y-6">
      <div class="card">
        <div class="card-header">
          <h2 class="card-title">Pesan terbaru</h2>
        </div>
        <div class="card-body p-0 sm:p-0">
          <% if (recentMessages.length === 0) { %>
            <div class="empty"><p class="empty-text">Belum ada pesan.</p></div>
          <% } else { %>
            <div>
              <% recentMessages.forEach(m => { %>
              <div class="activity-row">
                <div class="min-w-0 text-sm">
                  <p class="text-txt-primary font-medium truncate">→ <%= m.to_number %></p>
                  <p class="text-xs text-txt-muted truncate"><%= m.content || m.type %></p>
                </div>
                <span class="<%= m.direction === 'outbound' ? 'badge-success' : 'badge-muted' %> shrink-0">
                  <%= m.direction === 'outbound' ? 'Keluar' : 'Masuk' %>
                </span>
              </div>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>

      <div class="card">
        <div class="card-header flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
          <h2 class="card-title">Log sistem</h2>
          <a href="/dashboard/logs" class="btn-outline text-xs shrink-0">Lihat semua log →</a>
        </div>
        <div class="card-body">
          <% if (!auditLogs || auditLogs.length === 0) { %>
            <div class="empty"><p class="empty-text">Belum ada aktivitas.</p></div>
          <% } else { %>
            <div class="table-desktop">
              <table class="table text-xs">
                <thead><tr><th>Waktu</th><th>Kejadian</th><th>Detail</th></tr></thead>
                <tbody>
                  <% auditLogs.forEach(log => { %>
                  <tr>
                    <td class="whitespace-nowrap text-txt-muted"><%= log.created_at %></td>
                    <td class="text-txt-primary"><%= auditLabels[log.action] || log.action %></td>
                    <td class="truncate max-w-[200px]"><%= log.resource || log.ip_address || '—' %></td>
                  </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile bottom nav -->
  <nav class="mobile-bottom-nav" role="tablist" aria-label="Navigasi dashboard">
    <button type="button" class="mobile-nav-item active" data-tab="whatsapp" role="tab">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
      WhatsApp
    </button>
    <button type="button" class="mobile-nav-item" data-tab="apikeys" role="tab">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/></svg>
      API Key
    </button>
    <button type="button" class="mobile-nav-item" data-tab="integrate" role="tab">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
      Integrasi
    </button>
    <button type="button" class="mobile-nav-item" data-tab="activity" role="tab">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
      Aktivitas
    </button>
  </nav>

  <%- include('partials/layout-end') %>
  <script src="/public/js/dashboard.js?v=<%= assetVersion %>" defer></script>
</body>
</html>
