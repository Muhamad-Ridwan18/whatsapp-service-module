<% const displayName = currentUser?.name || currentUser?.phone || (currentUser?.email || '').split('@')[0]; %>
<% const initials = (displayName || 'A').charAt(0).toUpperCase(); %>
<% const subLabel = currentUser?.phone || currentUser?.email || ''; %>

<div class="app-shell">
  <div id="sidebarBackdrop" class="sidebar-backdrop" aria-hidden="true"></div>

  <aside id="sidebar" class="sidebar" aria-label="Navigasi utama">
    <div class="sidebar-brand">
      <span class="sidebar-brand-icon">W</span>
      <div>
        <p class="font-bold text-sm">WSM</p>
        <p class="text-[10px] text-txt-muted">WhatsApp Service</p>
      </div>
    </div>

    <nav class="sidebar-nav">
      <a href="/dashboard" class="<%= activePage === 'dashboard' ? 'sidebar-link-active' : 'sidebar-link' %>">Beranda</a>
      <a href="/dashboard/logs" class="<%= activePage === 'logs' ? 'sidebar-link-active' : 'sidebar-link' %>">Log</a>
      <% if (currentUser && currentUser.role === 'super_admin') { %>
      <a href="/dashboard/users" class="<%= activePage === 'users' ? 'sidebar-link-active' : 'sidebar-link' %>">Pengguna</a>
      <% } %>
      <a href="/dashboard/settings" class="<%= activePage === 'settings' ? 'sidebar-link-active' : 'sidebar-link' %>">Profil</a>
      <a href="/docs" class="sidebar-link">Dokumentasi</a>
    </nav>

    <div class="sidebar-footer">
      <div class="flex items-center gap-3 px-1 mb-2">
        <span class="sidebar-avatar"><%= initials %></span>
        <div class="min-w-0">
          <p class="text-sm font-medium truncate"><%= displayName %></p>
          <p class="text-[10px] text-txt-muted truncate"><%= subLabel %></p>
        </div>
      </div>
      <a href="/logout" class="sidebar-link text-txt-muted hover:text-red-400 text-xs">Keluar</a>
    </div>
  </aside>

  <div class="main-content">
    <header class="mobile-topbar">
      <div class="flex items-center gap-3 min-w-0">
        <button type="button" id="btnMenu" class="btn-icon" aria-label="Buka menu">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
        <p class="text-sm font-semibold truncate"><%= typeof pageTitle !== 'undefined' ? pageTitle : 'WSM' %></p>
      </div>
      <a href="/logout" class="btn-outline shrink-0">Keluar</a>
    </header>
