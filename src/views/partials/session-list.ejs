<% sessions.forEach(s => {
  const st = sessionStatus[s.status] || { label: s.status, class: 'badge-muted' };
%>
<div class="session-card">
  <div class="session-card-top">
    <div class="min-w-0 flex-1">
      <p class="session-card-id"><%= s.session_id %></p>
      <div class="session-card-meta mt-2">
        <span><%= s.phone_number || 'Belum ada nomor' %></span>
      </div>
    </div>
    <span class="<%= st.class %> shrink-0"><%= st.label %></span>
  </div>
  <div class="session-card-actions">
    <button type="button" class="btn-ghost text-brand btn-show-qr" data-session="<%= s.session_id %>">Tampilkan QR</button>
    <form method="POST" action="/dashboard/session/reconnect" class="inline">
      <button type="submit" class="btn-ghost">Sambung ulang</button>
    </form>
    <form method="POST" action="/dashboard/session/disconnect" class="inline">
      <button type="submit" class="btn-ghost">Putuskan</button>
    </form>
  </div>
</div>
<% }) %>
