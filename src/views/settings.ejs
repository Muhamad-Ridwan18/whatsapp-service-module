<!DOCTYPE html>
<html lang="id" class="dark">
<head>
  <%- include('partials/head', { title: 'Profil' }) %>
</head>
<body class="bg-surface min-h-screen font-sans text-gray-200">
  <%- include('partials/nav', { currentUser, activePage: 'settings' }) %>

  <main class="max-w-lg mx-auto px-4 py-6">
    <header class="mb-6">
      <h1 class="text-xl font-bold text-white">Profil &amp; Keamanan</h1>
      <p class="text-sm text-gray-500 mt-1">Kelola akun dan password Anda.</p>
    </header>

    <%- include('partials/alerts') %>

    <div class="card mb-4">
      <h2 class="section-title mb-4">Info Akun</h2>
      <dl class="space-y-3 text-sm">
        <div class="flex justify-between py-2 border-b border-surface-200/50">
          <dt class="text-gray-500">Email</dt>
          <dd class="text-white"><%= currentUser.email %></dd>
        </div>
        <div class="flex justify-between py-2">
          <dt class="text-gray-500">Peran</dt>
          <dd><span class="badge-success"><%= roleLabel %></span></dd>
        </div>
      </dl>
    </div>

    <div class="card">
      <h2 class="section-title mb-1">Ubah Password</h2>
      <p class="section-desc mb-4">Gunakan password kuat minimal 6 karakter.</p>
      <form method="POST" action="/dashboard/settings/password" class="space-y-4">
        <div>
          <label class="block text-xs font-medium text-gray-400 mb-1.5">Password saat ini</label>
          <input type="password" name="currentPassword" class="input-field" required autocomplete="current-password">
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-400 mb-1.5">Password baru</label>
          <input type="password" name="newPassword" minlength="6" class="input-field" required autocomplete="new-password">
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-400 mb-1.5">Ulangi password baru</label>
          <input type="password" name="confirmPassword" minlength="6" class="input-field" required autocomplete="new-password">
        </div>
        <button type="submit" class="btn-primary w-full">Simpan Password</button>
      </form>
    </div>
  </main>
</body>
</html>
