<!DOCTYPE html>
<html lang="id" class="dark">
<head>
  <%- include('partials/head', { title: 'Settings' }) %>
</head>
<body class="bg-surface min-h-screen font-sans text-gray-200">
  <%- include('partials/nav', { currentUser, activePage: 'settings' }) %>

  <main class="max-w-lg mx-auto px-4 py-6 space-y-4">
    <% if (errorMessage) { %>
      <div class="p-3 rounded-lg bg-red-500/10 border border-red-500/30 text-red-400 text-sm"><%= errorMessage %></div>
    <% } %>
    <% if (successMessage) { %>
      <div class="p-3 rounded-lg bg-accent/10 border border-accent/40 text-accent text-sm"><%= successMessage %></div>
    <% } %>

    <div class="card">
      <h2 class="text-sm font-semibold text-white mb-3">Ubah Password</h2>
      <form method="POST" action="/dashboard/settings/password" class="space-y-3">
        <div>
          <label class="block text-xs text-gray-400 mb-1">Password saat ini</label>
          <input type="password" name="currentPassword" class="input-field w-full" required>
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-1">Password baru</label>
          <input type="password" name="newPassword" minlength="6" class="input-field w-full" required>
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-1">Konfirmasi password baru</label>
          <input type="password" name="confirmPassword" minlength="6" class="input-field w-full" required>
        </div>
        <button type="submit" class="btn-primary w-full">Simpan Password</button>
      </form>
    </div>

    <div class="card">
      <h2 class="text-sm font-semibold text-white mb-2">Info Akun</h2>
      <dl class="text-sm space-y-1">
        <div class="flex justify-between"><dt class="text-gray-500">Email</dt><dd><%= currentUser.email %></dd></div>
        <div class="flex justify-between"><dt class="text-gray-500">Role</dt><dd class="text-accent"><%= currentUser.role %></dd></div>
      </dl>
    </div>
  </main>
</body>
</html>
