<!DOCTYPE html>
<html lang="id" class="dark">
<head>
  <%- include('partials/head', { title: 'Profil' }) %>
</head>
<body>
  <%- include('partials/sidebar', { currentUser, activePage: 'settings', pageTitle: 'Profil' }) %>

  <div class="page-inner">
    <header class="page-header">
      <p class="page-eyebrow">Akun</p>
      <h1 class="page-title">Profil &amp; keamanan</h1>
      <p class="page-subtitle">Kelola informasi akun dan ubah password Anda.</p>
    </header>

    <%- include('partials/alerts') %>

    <div class="grid gap-4 sm:gap-6 max-w-xl">
      <div class="card">
        <div class="card-header">
          <h2 class="card-title">Informasi akun</h2>
        </div>
        <div class="card-body space-y-0">
          <div class="flex justify-between items-center gap-4 py-3 border-b border-border">
            <span class="text-sm text-txt-muted">Email</span>
            <span class="text-sm font-medium text-right break-all"><%= currentUser.email %></span>
          </div>
          <div class="flex justify-between items-center gap-4 py-3">
            <span class="text-sm text-txt-muted">Peran</span>
            <span class="badge-success"><%= roleLabel %></span>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <h2 class="card-title">Ubah password</h2>
          <p class="card-desc">Minimal 6 karakter, gunakan kombinasi huruf dan angka.</p>
        </div>
        <div class="card-body">
          <form method="POST" action="/dashboard/settings/password" class="space-y-4">
            <div>
              <label class="label">Password saat ini</label>
              <input type="password" name="currentPassword" class="input" required autocomplete="current-password">
            </div>
            <div>
              <label class="label">Password baru</label>
              <input type="password" name="newPassword" minlength="6" class="input" required autocomplete="new-password">
            </div>
            <div>
              <label class="label">Ulangi password baru</label>
              <input type="password" name="confirmPassword" minlength="6" class="input" required autocomplete="new-password">
            </div>
            <button type="submit" class="btn-brand">Simpan password</button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <%- include('partials/layout-end') %>
</body>
</html>
