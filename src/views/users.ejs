<!DOCTYPE html>
<html lang="id" class="dark">
<head>
  <%- include('partials/head', { title: 'Pengguna' }) %>
</head>
<body class="bg-surface min-h-screen font-sans text-gray-200">
  <%- include('partials/nav', { currentUser, activePage: 'users' }) %>

  <main class="max-w-4xl mx-auto px-4 py-6">
    <header class="mb-6">
      <h1 class="text-xl font-bold text-white">Kelola Pengguna</h1>
      <p class="text-sm text-gray-500 mt-1">Buat akun klien atau admin untuk akses terbatas ke panel ini.</p>
    </header>

    <%- include('partials/alerts') %>

    <div class="card mb-6">
      <h2 class="section-title mb-1">Tambah Pengguna Baru</h2>
      <p class="section-desc mb-4">
        <strong>Klien</strong> — hanya lihat session miliknya &nbsp;·&nbsp;
        <strong>Admin</strong> — kelola session &amp; API key
      </p>
      <form method="POST" action="/dashboard/users/create" class="grid sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-medium text-gray-400 mb-1.5">Nama</label>
          <input type="text" name="name" placeholder="Nama lengkap" class="input-field" required>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-400 mb-1.5">Email</label>
          <input type="email" name="email" placeholder="klien@perusahaan.com" class="input-field" required>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-400 mb-1.5">Password</label>
          <input type="password" name="password" placeholder="Min. 6 karakter" minlength="6" class="input-field" required>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-400 mb-1.5">Peran</label>
          <select name="role" class="input-field">
            <option value="client">Klien</option>
            <option value="admin">Admin</option>
          </select>
        </div>
        <div class="sm:col-span-2">
          <button type="submit" class="btn-primary">Buat Pengguna</button>
        </div>
      </form>
    </div>

    <div class="card">
      <h2 class="section-title mb-4">Daftar Pengguna</h2>
      <div class="table-wrap">
        <table class="data-table">
          <thead>
            <tr>
              <th>Nama</th>
              <th>Email</th>
              <th>Peran</th>
              <th>Status</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach(u => { %>
              <tr>
                <td class="text-gray-200"><%= u.name %></td>
                <td class="text-gray-400"><%= u.email %></td>
                <td><span class="badge-muted"><%= u.role === 'super_admin' ? 'Super Admin' : u.role === 'admin' ? 'Admin' : 'Klien' %></span></td>
                <td>
                  <% if (u.is_active) { %><span class="badge-success">Aktif</span>
                  <% } else { %><span class="badge-error">Nonaktif</span><% } %>
                </td>
                <td>
                  <% if (u.is_active && u.id !== currentUser.id && u.role !== 'super_admin') { %>
                    <form method="POST" action="/dashboard/users/<%= u.id %>/deactivate" data-confirm="Nonaktifkan pengguna <%= u.email %>?">
                      <button type="submit" class="btn-danger">Nonaktifkan</button>
                    </form>
                  <% } else { %>
                    <span class="text-gray-600 text-xs">—</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
  <script src="/public/js/dashboard.js" defer></script>
</body>
</html>
