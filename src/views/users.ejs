<!DOCTYPE html>
<html lang="id" class="dark">
<head>
  <%- include('partials/head', { title: 'Pengguna' }) %>
</head>
<body>
  <%- include('partials/sidebar', { currentUser, activePage: 'users', pageTitle: 'Pengguna' }) %>

  <div class="page-inner">
    <header class="page-header">
      <p class="page-eyebrow">Manajemen</p>
      <h1 class="page-title">Pengguna</h1>
      <p class="page-subtitle">Buat akun klien: 1 nomor = 1 session = 1 API key (otomatis).</p>
    </header>

    <%- include('partials/alerts') %>

    <div class="space-y-4 sm:space-y-6">
      <div class="card">
        <div class="card-header">
          <h2 class="card-title">Tambah akun klien</h2>
          <p class="card-desc">Session <code class="text-brand font-mono text-xs">wa-&lt;nomor&gt;</code> dan API key dibuat otomatis.</p>
        </div>
        <div class="card-body">
          <form method="POST" action="/dashboard/users/create" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="label">Nama</label>
              <input type="text" name="name" placeholder="Nama bisnis / toko" class="input" required>
            </div>
            <div>
              <label class="label">Nomor WhatsApp</label>
              <input type="tel" name="phone" placeholder="628123456789" class="input" required>
              <p class="hint">Dipakai untuk login, session, dan API.</p>
            </div>
            <div class="sm:col-span-2">
              <label class="label">Password awal</label>
              <input type="password" name="password" minlength="6" placeholder="Min. 6 karakter" class="input" required>
            </div>
            <div class="sm:col-span-2">
              <button type="submit" class="btn-brand">Buat akun klien</button>
            </div>
          </form>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <h2 class="card-title">Daftar pengguna</h2>
          <p class="card-desc"><%= users.length %> akun terdaftar</p>
        </div>
        <div class="card-body">
          <div class="md:hidden space-y-3">
            <% users.forEach(u => { %>
            <div class="session-card">
              <div class="session-card-top">
                <div class="min-w-0">
                  <p class="text-sm font-medium text-txt-primary"><%= u.name %></p>
                  <p class="text-xs text-txt-muted truncate"><%= u.phone_number || u.email %></p>
                </div>
                <% if (u.is_active) { %><span class="badge-success">Aktif</span><% } else { %><span class="badge-error">Nonaktif</span><% } %>
              </div>
              <p class="text-xs text-txt-muted">
                <%= u.role === 'super_admin' ? 'Super Admin' : u.role === 'admin' ? 'Admin' : 'Klien' %>
              </p>
              <% if (u.is_active && u.id !== currentUser.id && u.role !== 'super_admin') { %>
              <form method="POST" action="/dashboard/users/<%= u.id %>/deactivate" data-confirm="Nonaktifkan akun <%= u.phone_number || u.email %>?">
                <button type="submit" class="btn-danger">Nonaktifkan</button>
              </form>
              <% } %>
            </div>
            <% }) %>
          </div>
          <div class="table-desktop">
            <table class="table">
              <thead>
                <tr><th>Nama</th><th>Nomor / Email</th><th>Peran</th><th>Status</th><th></th></tr>
              </thead>
              <tbody>
                <% users.forEach(u => { %>
                <tr>
                  <td class="text-txt-primary font-medium"><%= u.name %></td>
                  <td><%= u.phone_number || u.email %></td>
                  <td><span class="badge-muted"><%= u.role === 'super_admin' ? 'Super Admin' : u.role === 'admin' ? 'Admin' : 'Klien' %></span></td>
                  <td><% if (u.is_active) { %><span class="badge-success">Aktif</span><% } else { %><span class="badge-error">Nonaktif</span><% } %></td>
                  <td>
                    <% if (u.is_active && u.id !== currentUser.id && u.role !== 'super_admin') { %>
                    <form method="POST" action="/dashboard/users/<%= u.id %>/deactivate" data-confirm="Nonaktifkan akun <%= u.phone_number || u.email %>?">
                      <button type="submit" class="btn-danger">Nonaktifkan</button>
                    </form>
                    <% } %>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%- include('partials/layout-end') %>
  <script src="/public/js/dashboard.js?v=<%= assetVersion %>" defer></script>
</body>
</html>
