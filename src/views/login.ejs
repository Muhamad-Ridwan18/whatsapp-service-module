<!DOCTYPE html>
<html lang="id" class="dark">
<head>
  <%- include('partials/head', { title: 'Masuk' }) %>
</head>
<body>
  <div class="login-shell">
    <div class="login-card animate-fade-in">
      <div class="text-center mb-8">
        <div class="sidebar-brand-icon w-14 h-14 text-xl mx-auto mb-5">W</div>
        <h1 class="text-2xl font-bold tracking-tight">Selamat datang</h1>
        <p class="text-sm text-txt-secondary mt-2">Masuk ke panel WhatsApp Service Module</p>
      </div>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-error mb-6">Email atau password salah.</div>
      <% } %>

      <form method="POST" action="/login" class="space-y-5">
        <div>
          <label class="label">Email</label>
          <input type="email" name="email" required class="input" placeholder="admin@localhost" autocomplete="email">
        </div>
        <div>
          <label class="label">Password</label>
          <input type="password" name="password" required class="input" placeholder="••••••••" autocomplete="current-password">
        </div>
        <button type="submit" class="btn-brand w-full">Masuk ke Dashboard</button>
      </form>

      <p class="text-center text-xs text-txt-muted mt-8">
        <a href="/docs" class="text-brand hover:text-brand-light transition-colors">Dokumentasi API →</a>
      </p>
    </div>
  </div>
</body>
</html>
